# =====================================================
# Task Management SaaS — Environment Variables
# =====================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# =====================================================

# ── General ──
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=change-me-to-a-random-50-char-string
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (PostgreSQL) ──
POSTGRES_DB=taskmanager
POSTGRES_USER=taskmanager
POSTGRES_PASSWORD=taskmanager_secret
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://taskmanager:taskmanager_secret@postgres:5432/taskmanager

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1
CHANNELS_REDIS_URL=redis://redis:6379/2

# ── JWT ──
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7

# ── CORS ──
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:80

# ── Email ──
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@taskmanager.com

# ── AWS (Production) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=

# ── Sentry (Production) ──
SENTRY_DSN=

# ── Frontend ──
API_URL=http://localhost:8000/api/v1
WS_URL=ws://localhost:8000/ws
